# Spectraloop — ortam değişkenleri şablonu
# Bu dosya git'e girer ve SADECE placeholder içerir. Gerçek değerleri .env.local'a
# yaz (gitignored). Kopyala: cp .env.example .env.local

# --- Veritabanı ---
MONGODB_URI=            # Backend (0.2) — Mongoose bağlantı stringi (MongoDB Atlas)

# --- Auth (Faz 2) ---
AUTH_SECRET=            # Auth.js — ZORUNLU (prod). Üret: openssl rand -base64 32
NEXTAUTH_URL=           # Auth.js callback base URL (ör. http://localhost:3000)
SEED_ADMIN_EMAIL=       # seed:admin — ilk admin kullanıcının e-postası
SEED_ADMIN_PASSWORD=    # seed:admin — ilk admin parolası (seed sonrası değiştir)

# --- E-posta ---
RESEND_API_KEY=         # Resend — iletişim/başvuru bildirim mailleri
MAIL_FROM=              # Resend — gönderen adresi (opsiyonel; boşsa Resend onboarding sender)
TEAM_NOTIFY_EMAIL=      # Başvuru/iletişim bildirimi alıcısı (opsiyonel; boşsa mail atlanır)

# --- Dosya depolama (Cloudflare R2) ---
R2_ACCOUNT_ID=          # Cloudflare R2 — hesap ID
R2_ACCESS_KEY_ID=       # Cloudflare R2 — erişim anahtarı ID
R2_SECRET_ACCESS_KEY=   # Cloudflare R2 — gizli erişim anahtarı
R2_BUCKET=              # Cloudflare R2 — bucket adı
R2_PUBLIC_BASE_URL=     # R2 public/CDN taban URL'i (ör. https://cdn.example.com) — fileUrl için (3.B4)
