# Spectraloop — ortam değişkenleri şablonu
# Bu dosya git'e girer ve SADECE placeholder içerir. Gerçek değerleri .env.local'a
# yaz (gitignored). Kopyala: cp .env.example .env.local
#
# [ZORUNLU] = Vercel production'da mutlaka ayarla. [ops] = opsiyonel.
# Deploy adımları + ayrıntılı env tablosu: docs/DEPLOY.md

# --- Veritabanı ---
MONGODB_URI=            # [ZORUNLU] Mongoose bağlantı stringi (MongoDB Atlas). Atlas IP allowlist'e 0.0.0.0/0 ekle (Vercel)

# --- Auth (Faz 2) ---
AUTH_SECRET=            # [ZORUNLU] Auth.js — prod'da şart. Üret: openssl rand -base64 32 (veya npx auth secret)
NEXTAUTH_URL=           # [ops] Kanonik site URL'i (ör. https://spectraloop.vercel.app). Auth.js v5'te AUTH_URL de olur.
                        #        Vercel'de trustHost:true + VERCEL_URL ile otomatik; yine de kanonik domain için önerilir.
SEED_ADMIN_EMAIL=       # [ZORUNLU-seed] seed:admin — ilk admin kullanıcının e-postası (sadece seed anında)
SEED_ADMIN_PASSWORD=    # [ZORUNLU-seed] seed:admin — ilk admin parolası (seed sonrası panelden değiştir)

# --- E-posta ---
RESEND_API_KEY=         # [ops] Resend — iletişim/başvuru bildirim mailleri (boşsa mail atlanır, form yine 201)
MAIL_FROM=              # [ops] Resend — gönderen adresi (boşsa Resend onboarding sender; doğrulanmış domain önerilir)
TEAM_NOTIFY_EMAIL=      # [ops] Başvuru/iletişim bildirimi alıcısı (boşsa mail atlanır)

# --- Dosya depolama (Cloudflare R2) ---
R2_ACCOUNT_ID=          # [ZORUNLU-upload] Cloudflare R2 — hesap ID
R2_ACCESS_KEY_ID=       # [ZORUNLU-upload] Cloudflare R2 — erişim anahtarı ID
R2_SECRET_ACCESS_KEY=   # [ZORUNLU-upload] Cloudflare R2 — gizli erişim anahtarı
R2_BUCKET=              # [ZORUNLU-upload] Cloudflare R2 — bucket adı
R2_PUBLIC_BASE_URL=     # [ZORUNLU-upload] R2 public/CDN taban URL'i (ör. https://cdn.example.com veya https://pub-xxxx.r2.dev)
                        #        fileUrl bununla kurulur; boşsa link public erişilebilir DEĞİL (S3 endpoint'e düşer).

# --- Site ---
NEXT_PUBLIC_SITE_URL=   # [ops] Kanonik public URL (ör. https://spectraloop.vercel.app). Server component'lerin iç API
                        #        fetch'i için; Vercel'de VERCEL_URL'e düşer. Özel domain kullanıyorsan ayarlaman önerilir.
